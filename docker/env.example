# Copiar a .env en esta misma carpeta (docker/.env):
#   copy env.example .env   (Windows, desde docker/)
# Ajusta contraseñas en entornos reales; no subas .env a Git.

POSTGRES_DB=microrm
POSTGRES_USER=microrm
POSTGRES_PASSWORD=microrm_dev
POSTGRES_PORT=5432

# Puertos publicados en el host
# Entrada HTTP única (WAF → gateway → API)
WAF_PORT=8080
API_PORT=8081

# ModSecurity / OWASP CRS (microrm-waf)
MODSEC_RULE_ENGINE=On
MODSEC_BLOCKING_PARANOIA=1
MODSEC_ANOMALY_INBOUND=10

# Auth0 (misma audience que VITE_AUTH0_AUDIENCE en FrontMicroRm)
AUTH_ENABLED=true
AUTH0_ISSUER_URI=https://dev-8b6v5b1m5lue1prr.us.auth0.com/
AUTH0_AUDIENCE=https://microrm-api/
